rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ⚠️ Replace with the coach's real Gmail. Keep in sync with firestore.rules.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['yigitleromer@gmail.com'];
    }

    // Testimonial before/after images — public read, admin-only write.
    match /testimonials/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
