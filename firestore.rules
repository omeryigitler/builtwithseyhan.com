rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only allow-listed, email-verified Google accounts count as admin.
    // ⚠️ Replace with the coach's real Gmail. Add more inside the list if needed.
    // Keep this in sync with VITE_ADMIN_EMAILS (client) and storage.rules.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['yigitleromer@gmail.com'];
    }

    // Public content — anyone can read, only the admin can write.
    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Leads are written ONLY by the server (Admin SDK bypasses these rules).
    // Clients can never create leads; only the admin can read them.
    match /leads/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
