# ─── Site ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://builtwithseyhan.com

# ─── Supabase (client) — Project Settings > API ─────────────────────────
# These are public (sent to the browser). Security is enforced by RLS policies.
# The key may be the new "publishable" key (sb_publishable_…) OR the legacy
# anon JWT (eyJ…) — both work as the public client key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# ─── Supabase (server only — never sent to the browser) ─────────────────
# Used by server-side admin actions / on-demand revalidation. Vercel env only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Google account(s), comma-separated. Must match the `admins` table seeded
# in the SQL migration. Only these emails can use the admin panel.
NEXT_PUBLIC_ADMIN_EMAILS=yigitleromer@gmail.com

# ─── Email (optional) — Resend, for the e-book / welcome email ────────────
# Get a key at resend.com. Without it, subscribers are stored but no email is sent.
# RESEND_FROM must be a verified domain (e.g. "Built With Seyhan <hi@builtwithseyhan.com>").
RESEND_API_KEY=
RESEND_FROM=

# E-book download link emailed to new subscribers. Optional: defaults to the
# /ebook.pdf shipped with the deployment. Set this to a stable URL (e.g. a
# Supabase Storage public link) if you host the PDF outside the repo.
EBOOK_URL=
