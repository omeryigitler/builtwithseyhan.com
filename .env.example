# ─── Site ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://builtwithseyhan.com

# ─── Supabase (client) — Project Settings > API ─────────────────────────
# These are public (sent to the browser). Security is enforced by RLS policies.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase (server only — never sent to the browser) ─────────────────
# Used by server-side admin actions / on-demand revalidation. Vercel env only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Google account(s), comma-separated. Must match the `admins` table seeded
# in the SQL migration. Only these emails can use the admin panel.
NEXT_PUBLIC_ADMIN_EMAILS=yigitleromer@gmail.com
