# ─── Cal.com / İletişim ──────────────────────────────────────────────
VITE_SCHEDULING_URL=https://cal.com/your-handle/analysis
VITE_CONTACT_EMAIL=contact@builtwithseyhan.com
VITE_LINKEDIN_URL=https://www.linkedin.com/in/your-profile/
VITE_X_URL=https://x.com/your-profile
VITE_SITE_URL=https://builtwithseyhan.com/

# ─── Firebase (client) — Console > Project settings > Web app config ──
# Bu değerler gizli değildir, tarayıcıya gönderilir. Güvenlik, Firestore/Storage
# kuralları + Auth ile sağlanır.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin Google hesabı/hesapları (virgülle ayır). firestore.rules + storage.rules
# içindeki e-posta ile AYNI olmalı. Yalnız bu adresler admin paneline girebilir.
VITE_ADMIN_EMAILS=yigitleromer@gmail.com

# ─── Sunucu tarafı (SADECE Vercel env, .env'e koymayın, tarayıcıya gitmez) ──
# api/contact.ts tarafından kullanılır.
# RESEND_API_KEY=re_xxx
# CONTACT_EMAIL=contact@builtwithseyhan.com
# Firebase Admin: Console > Project settings > Service accounts > Generate key
# JSON'u tek satıra sıkıştırıp şuraya koyun:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
